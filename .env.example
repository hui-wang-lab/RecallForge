# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://localhost:5432/recallforge

# ── Embedding ─────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-v4@1024
EMBEDDING_DIM=1024
EMBEDDING_PROVIDER=dashscope

# ── API Keys ──────────────────────────────────────────────
OPENAI_API_KEY=change_me
OPENAI_BASE_URL=

# ── Reranker ──────────────────────────────────────────────
RERANKER_MODEL=
RERANKER_PROVIDER=

# ── Retrieval ─────────────────────────────────────────────
DEFAULT_TOP_K=30
FINAL_TOP_K=8

# ── Chunking ──────────────────────────────────────────────
CHILD_MAX_TOKENS=450
CHILD_MIN_TOKENS=80
PARENT_GRANULARITY=chapter

# ── Observability ─────────────────────────────────────────
LOG_LEVEL=INFO
