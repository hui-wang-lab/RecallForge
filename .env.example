# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://localhost:5432/recallforge

# ── Embedding ─────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-v4@1024
EMBEDDING_DIM=1024
EMBEDDING_PROVIDER=dashscope

# ── API Keys ──────────────────────────────────────────────
OPENAI_API_KEY=change_me
OPENAI_BASE_URL=

# ── Reranker ──────────────────────────────────────────────
RERANKER_MODEL=
RERANKER_PROVIDER=
RERANKER_TOP_K=50
RERANKER_API_KEY=
RERANKER_ENDPOINT=
RERANKER_REQUEST_TIMEOUT_SECONDS=30.0
RERANKER_MAX_RETRIES=3

# ── Retrieval ─────────────────────────────────────────────
DEFAULT_TOP_K=50
FINAL_TOP_K=8
RERANKER_REQUIRED=True
MIN_RERANK_SCORE=0.35
MIN_VECTOR_SCORE=0.6
MIN_TOP1_MARGIN=0.05
MAX_CONTEXT_TOKENS=24000
QUERY_REWRITE_ENABLED=False
HYDE_ENABLED=False
MIN_QUERY_LENGTH=2
PARENT_CONTEXT_WINDOW_TOKENS=2000
SEARCH_MODE=vector

# ── Chunking ──────────────────────────────────────────────
CHILD_MAX_TOKENS=450
CHILD_MIN_TOKENS=80
PARENT_GRANULARITY=chapter

# ── Observability ─────────────────────────────────────────
LOG_LEVEL=INFO
